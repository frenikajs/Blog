Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Protect sensitive files
<FilesMatch "^(config\.php|install\.php|composer\.json|\.env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow config and install from server only (override above for install)
<Files "install.php">
    Order Deny,Allow
    Deny from all
    Allow from 127.0.0.1
    Allow from ::1
</Files>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml text/xml text/plain image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect www to non-www (or reverse — uncomment one)
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    # Force HTTPS (uncomment when SSL is active)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Feed
    RewriteRule ^feed/?$              feed.php                     [L,QSA]
    RewriteRule ^feed\.xml$           feed.php                     [L,QSA]

    # Sitemap
    RewriteRule ^sitemap\.xml$        sitemap.xml.php              [L,QSA]

    # Search
    RewriteRule ^search/?$            search.php                   [L,QSA]

    # Category archive
    RewriteRule ^category/([a-z0-9-]+)/?$ index.php?category=$1   [L,QSA]

    # Tag archive
    RewriteRule ^tag/([a-z0-9-]+)/?$  index.php?tag=$1            [L,QSA]

    # Single post (slug — must come last, most generic)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9-]+)/?$      post.php?slug=$1            [L,QSA]
</IfModule>
